APP_NAME="CRM API Tests"
APP_ENV=testing
APP_DEBUG=true
APP_KEY=base64:1234567890123456789012345678901234567890123=

# MySQL for tenant tests - matches InteractsWithTenancy trait
# Note: DB_DATABASE not set - handled by config/database.php based on APP_ENV
DB_CONNECTION=mysql

# Disable tenancy DB auto-creation (we handle it manually)
TENANCY_DATABASE_AUTO_CREATE=false
TENANCY_DATABASE_AUTO_DELETE=false

# Fast password hashing
BCRYPT_ROUNDS=4

# In-memory caching and sessions
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# Disable mail/broadcast
MAIL_MAILER=array
BROADCAST_CONNECTION=null

# Disable optional services
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
